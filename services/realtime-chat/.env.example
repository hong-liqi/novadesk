# Realtime Chat Service — Environment Variables
# Copy to .env for local development.

NODE_ENV=development
LOG_LEVEL=debug
SERVICE_NAME=realtime-chat-service
PORT=3005

# Infrastructure
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://portfolio:portfolio@localhost:5436/chat_db

# JWT validation (JWKS fetched from auth service)
JWT_ISSUER=portfolio-os-auth
JWT_AUDIENCE=portfolio-os
AUTH_JWKS_URL=http://localhost:3001/.well-known/jwks.json

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
SENTRY_DSN=
