{
  "name": "@novadesk/realtime-chat-service",
  "version": "0.1.0",
  "private": true,
  "description": "Realtime chat WebSocket service for NovaDesk",
  "scripts": {
    "build": "prisma generate && nest build && tsc-alias -p tsconfig.build.json && mkdir -p dist/generated && cp -r src/generated/prisma dist/generated/prisma",
    "dev": "nest start --watch",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:integration": "jest --config ./test/jest-e2e.json",
    "clean": "rm -rf dist",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "sh ../../infrastructure/scripts/prisma-deploy.sh"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/platform-socket.io": "^10.4.15",
    "@nestjs/swagger": "^8.1.0",
    "@nestjs/terminus": "^10.2.3",
    "@nestjs/websockets": "^10.4.15",
    "@opentelemetry/auto-instrumentations-node": "^0.52.1",
    "@opentelemetry/sdk-node": "^0.57.1",
    "@novadesk/auth": "workspace:*",
    "@novadesk/config": "workspace:*",
    "@novadesk/logger": "workspace:*",
    "@novadesk/shared": "workspace:*",
    "@prisma/client": "^7.8.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/testing": "^10.4.15",
    "@novadesk/eslint-config": "workspace:*",
    "@novadesk/tsconfig": "workspace:*",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsc-alias": "^1.8.10",
    "typescript": "^5.7.2"
  }
}
