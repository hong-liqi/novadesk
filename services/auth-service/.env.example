# Auth Service — Environment Variables
# Copy to .env for local development.

NODE_ENV=development
LOG_LEVEL=debug
SERVICE_NAME=auth-service
PORT=3001

# Infrastructure
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://portfolio:portfolio@localhost:5432/auth_db

# JWT (RS256) — dev key pair below; generate your own for production
