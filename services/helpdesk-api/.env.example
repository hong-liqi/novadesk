# Helpdesk API — Environment Variables
# Copy to .env for local development.

NODE_ENV=development
LOG_LEVEL=debug
SERVICE_NAME=helpdesk-api
PORT=3003

# Infrastructure
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://novadesk:novadesk@localhost:5434/helpdesk_db

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
SENTRY_DSN=
