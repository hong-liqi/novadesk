generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TicketMetricDaily {
  id            String   @id @default(uuid()) @db.Uuid
  workspaceId   String   @map("workspace_id") @db.Uuid
  date          DateTime @db.Date
  openCount     Int      @map("open_count")
  createdCount  Int      @map("created_count")
  resolvedCount Int      @map("resolved_count")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([workspaceId, date])
  @@index([workspaceId, date])
  @@map("ticket_metrics_daily")
}

model WorkspaceKpiSnapshot {
  id                     String   @id @default(uuid()) @db.Uuid
  workspaceId            String   @map("workspace_id") @db.Uuid
  openTickets            Int      @map("open_tickets")
  resolvedTickets        Int      @map("resolved_tickets")
  avgResolutionTimeHours Float    @map("avg_resolution_time_hours")
  capturedAt             DateTime @default(now()) @map("captured_at")

  @@index([workspaceId, capturedAt])
  @@map("workspace_kpi_snapshots")
}
