# Gateway — Environment Variables
# Copy to .env for local development.

NODE_ENV=development
LOG_LEVEL=debug
SERVICE_NAME=gateway
PORT=3000

# Infrastructure
REDIS_URL=redis://localhost:6379

# Downstream services
AUTH_SERVICE_URL=http://localhost:3001
NOTIFICATION_SERVICE_URL=http://localhost:3002
HELPDESK_SERVICE_URL=http://localhost:3003
ANALYTICS_SERVICE_URL=http://localhost:3004
REALTIME_CHAT_SERVICE_URL=http://localhost:3005

# JWT validation (JWKS fetched from auth service)
JWT_ISSUER=novadesk-auth
JWT_AUDIENCE=novadesk
AUTH_JWKS_URL=http://localhost:3001/.well-known/jwks.json

# Rate limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Proxy
PROXY_TIMEOUT_MS=10000

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
SENTRY_DSN=
