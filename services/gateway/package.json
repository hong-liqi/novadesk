{
  "name": "@novadesk/gateway",
  "version": "0.1.0",
  "private": true,
  "description": "API gateway for NovaDesk",
  "scripts": {
    "build": "nest build && tsc-alias -p tsconfig.build.json",
    "dev": "nest start --watch",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:integration": "jest --config ./test/jest-e2e.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^8.1.0",
    "@nestjs/terminus": "^10.2.3",
    "@nestjs/throttler": "^6.4.0",
    "@opentelemetry/auto-instrumentations-node": "^0.52.1",
    "@opentelemetry/sdk-node": "^0.57.1",
    "@novadesk/auth": "workspace:*",
    "@novadesk/config": "workspace:*",
    "@novadesk/logger": "workspace:*",
    "@novadesk/shared": "workspace:*",
    "helmet": "^8.0.0",
    "http-proxy-middleware": "^3.0.3",
    "ioredis": "^5.4.2",
    "jose": "^5.9.6",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.24",
    "@nestjs/testing": "^11.1.28",
    "@novadesk/eslint-config": "workspace:*",
    "@novadesk/tsconfig": "workspace:*",
    "@types/express": "^5.0.0",
    "@types/http-proxy-middleware": "^1.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.1",
    "eslint": "^10.7.0",
    "jest": "^30.4.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsc-alias": "^1.9.1",
    "typescript": "^7.0.2"
  }
}
