{
  "name": "@novadesk/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared contracts, helpers, constants and standard errors for NovaDesk",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./constants": {
      "types": "./dist/constants/index.d.ts",
      "default": "./dist/constants/index.js"
    },
    "./dtos": {
      "types": "./dist/dtos/index.d.ts",
      "default": "./dist/dtos/index.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "default": "./dist/errors/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "default": "./dist/schemas/index.js"
    },
    "./types": {
      "types": "./dist/types/api.d.ts",
      "default": "./dist/types/api.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "default": "./dist/utils/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint": "eslint src --ignore-pattern '**/*.spec.ts'",
    "typecheck": "tsc --noEmit",
    "test": "jest --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@novadesk/eslint-config": "workspace:*",
    "@novadesk/tsconfig": "workspace:*",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.2.5",
    "typescript": "^6.0.3"
  }
}
