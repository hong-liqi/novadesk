{
  "name": "@novadesk/sdk",
  "version": "0.1.0",
  "private": true,
  "description": "Reusable typed HTTP client foundation for NovaDesk APIs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./interceptors": {
      "types": "./dist/interceptors.d.ts",
      "default": "./dist/interceptors.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "default": "./dist/errors.js"
    },
    "./retry": {
      "types": "./dist/retry.d.ts",
      "default": "./dist/retry.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint": "eslint src --ignore-pattern '**/*.spec.ts'",
    "typecheck": "tsc --noEmit",
    "test": "jest --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@novadesk/shared": "workspace:*"
  },
  "devDependencies": {
    "@novadesk/eslint-config": "workspace:*",
    "@novadesk/tsconfig": "workspace:*",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.2.5",
    "typescript": "^6.0.3"
  }
}
