{
  "name": "@novadesk/auth",
  "version": "0.1.0",
  "private": true,
  "description": "Authentication foundation with JWT, refresh token and RBAC primitives for NovaDesk",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./guards": {
      "types": "./dist/guards/index.d.ts",
      "default": "./dist/guards/index.js"
    },
    "./decorators": {
      "types": "./dist/decorators/index.d.ts",
      "default": "./dist/decorators/index.js"
    },
    "./helpers": {
      "types": "./dist/helpers/index.d.ts",
      "default": "./dist/helpers/index.js"
    },
    "./middlewares": {
      "types": "./dist/middlewares/index.d.ts",
      "default": "./dist/middlewares/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint": "eslint src --ignore-pattern '**/*.spec.ts'",
    "typecheck": "tsc --noEmit",
    "test": "jest --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@novadesk/shared": "workspace:*",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@novadesk/eslint-config": "workspace:*",
    "@novadesk/tsconfig": "workspace:*",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "react": "^18.3.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "react": "^18.0.0"
  }
}
