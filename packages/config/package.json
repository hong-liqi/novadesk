{
  "name": "@novadesk/config",
  "version": "0.1.0",
  "private": true,
  "description": "Typed and validated environment configuration schemas for NovaDesk",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "default": "./dist/schemas/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./create-config": {
      "types": "./dist/create-config.d.ts",
      "default": "./dist/create-config.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint": "eslint src --ignore-pattern '**/*.spec.ts'",
    "typecheck": "tsc --noEmit",
    "test": "jest --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@novadesk/shared": "workspace:*",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@novadesk/eslint-config": "workspace:*",
    "@novadesk/tsconfig": "workspace:*",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.2.5",
    "typescript": "^6.0.3"
  }
}
