{
  "name": "@portfolio/tsconfig",
  "version": "0.1.0",
  "private": true,
  "description": "Shared TypeScript configuration presets for Portfolio OS",
  "main": "./base.json",
  "exports": {
    ".": "./base.json",
    "./base": "./base.json",
    "./base.json": "./base.json",
    "./node": "./node.json",
    "./node.json": "./node.json",
    "./react": "./react.json",
    "./react.json": "./react.json",
    "./nestjs": "./nestjs.json",
    "./nestjs.json": "./nestjs.json"
  },
  "files": [
    "base.json",
    "node.json",
    "react.json",
    "nestjs.json",
    "README.md"
  ],
  "scripts": {
    "build": "node ./test/validate.mjs",
    "lint": "node ./test/validate.mjs",
    "test": "node --test ./test/config.test.mjs",
    "typecheck": "node ./test/validate.mjs"
  }
}
