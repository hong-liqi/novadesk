{
  "name": "@portfolio/eslint-config",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared ESLint flat config presets for Portfolio OS",
  "main": "./base.js",
  "exports": {
    ".": "./base.js",
    "./base": "./base.js",
    "./node": "./node.js",
    "./react": "./react.js",
    "./nestjs": "./nestjs.js"
  },
  "scripts": {
    "build": "node ./test/validate.mjs",
    "lint": "node ./test/validate.mjs",
    "test": "node --test ./test/config.test.mjs",
    "typecheck": "node ./test/validate.mjs"
  },
  "dependencies": {
    "@eslint/js": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "globals": "^15.14.0",
    "typescript-eslint": "^8.18.1"
  },
  "peerDependencies": {
    "eslint": "^9.0.0"
  }
}
