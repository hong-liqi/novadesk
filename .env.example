# NovaDesk — Environment Variables
# Copy to .env and adjust values for local development.

# Global
NODE_ENV=development
LOG_LEVEL=debug

# Infrastructure
REDIS_URL=redis://localhost:6379

# PostgreSQL (per service — foundation only, no migrations yet)
AUTH_DATABASE_URL=postgresql://novadesk:novadesk@localhost:5432/auth_db
NOTIFICATION_DATABASE_URL=postgresql://novadesk:novadesk@localhost:5433/notification_db

# JWT (generate RSA keys for production)
JWT_PUBLIC_KEY=
JWT_PRIVATE_KEY=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Service ports
GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
NOTIFICATION_SERVICE_PORT=3002

# App ports
HELPDESK_APP_PORT=3010
ANALYTICS_APP_PORT=3011
ADMIN_PANEL_PORT=3012
REALTIME_CHAT_APP_PORT=3014
WEBSITE_PORT=3013

# URLs (local)
API_GATEWAY_URL=http://localhost/api
NEXT_PUBLIC_API_URL=http://localhost/api

# SMTP (Notification Service — Mailpit in local)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@novadesk.dev

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
SENTRY_DSN=

# CORS
CORS_ORIGINS=http://localhost:3010,http://localhost:3011,http://localhost:3012,http://localhost:3013,http://localhost:3014
